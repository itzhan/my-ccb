# ============================================
# Claude Code Gateway 配置文件
# ============================================

# --- 服务器 ---
SERVER_HOST=0.0.0.0
SERVER_PORT=5674

# --- TLS（可选，留空则使用 HTTP） ---
# TLS_CERT_FILE=/path/to/cert.pem
# TLS_KEY_FILE=/path/to/key.pem

# --- 数据库 ---
# 驱动: sqlite（默认）或 postgres
DATABASE_DRIVER=sqlite
# SQLite: 文件路径；Postgres: 连接字符串
DATABASE_DSN=data/claude-code-gateway.db

# Postgres 示例:
# DATABASE_DRIVER=postgres
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_USER=postgres
# DATABASE_PASSWORD=your_password
# DATABASE_DBNAME=ccgateway

# --- Redis（可选，留空则使用内存缓存） ---
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# --- 管理员 ---
ADMIN_PASSWORD=admin

# --- 出口指纹 ---
# craftls（默认，内置 Bun 指纹快照，会随 Claude Code 升级过时）
# bun_sidecar（推荐，经本地 Bun 边车发出，TLS 指纹永远等于真实 Bun，自动跟随）
# EGRESS_MODE=bun_sidecar
# BUN_SIDECAR_PORT=8788

# --- 身份模式 ---
# passthrough（默认,单人:客户端请求原样透传,最高保真)
# normalize（多人共号:把 home用户名/git/OS/device_id 归一化成账号固定虚拟身份,
#            让一个号始终像同一个人。版本/TLS 指纹不受影响)
# IDENTITY_MODE=passthrough
# normalize 模式下,是否透传真实文件系统路径(home用户名/cwd/memory slug/Windows 路径)。
# simulate（默认:把路径里的真实用户名改写成虚拟用户名,隐私最高）
# passthrough（真实绝对路径原样发出,git名/平台/OS/device_id 仍归一化;
#              用于 Claude 需要按真实 cwd 做文件操作、否则路径串掉的场景。会暴露真实用户名）
# 账号可在面板单独设 path_mode 覆盖此默认值。
# PATH_MODE=simulate

# --- 限速（削峰防封） ---
# 全局默认每分钟请求上限：超过则换号，全部账号都满则排队等待（最长 20s），
# 把瞬时突发匀速化，避免触发官方"短时高速率"风控。0/不设=不限。
# 账号可在面板单独设 rpm_limit 覆盖此默认值。
# DEFAULT_RPM_LIMIT=18

# --- 5h 窗口的消费上限（USD，按官方价格表算）---
# 按 Anthropic 官方 5h 窗口对齐:窗口起=usage_data.five_hour.resets_at-5h。
# 窗口内累计成本(input+output+cache write/read)达此值则跳过(其他号顶上),
# 到 reset 时间后下一次请求自动启动新窗口。0/不设=不限。
# 需先在面板拉取一次用量获取重置时间(自动周期拉取也可)。
# Max 20x 推荐 $250;Max 5x 推荐 $80;Pro 推荐 $40。账号可在面板单独覆盖。
# DEFAULT_5H_COST_CAP_USD=250

# --- 客户端限制 ---
# off    = 不限制（默认，普通 API 客户端也会被伪装成 CC 转发）
# ua     = 仅校验 User-Agent 是 claude-code/claude-cli（SDK/VSCode 也放行）
# cli    = 仅交互式 Claude Code：UA + 客户端类型 ∈ {cli, claude-vscode}，
#          挡掉 Agent SDK 程序化调用（sdk-cli/sdk-ts/local-agent）和 desktop-3p
# strict = 严格：UA + 系统提示相似度 + 必需 header，只放行真实 Claude Code 客户端
CLIENT_RESTRICTION=off

# --- 日志 ---
# 级别: debug, info, warn, error
LOG_LEVEL=info

# --- 用量轮询 ---
# 账户 usage 数据自动刷新间隔（秒），默认 300（5 分钟）
USAGE_POLL_INTERVAL_SECS=300
