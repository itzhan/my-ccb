# ============================================
# Claude Code Gateway 配置文件
# ============================================

# --- 服务器 ---
SERVER_HOST=0.0.0.0
SERVER_PORT=5674

# --- TLS（可选，留空则使用 HTTP） ---
# TLS_CERT_FILE=/path/to/cert.pem
# TLS_KEY_FILE=/path/to/key.pem

# --- 数据库 ---
# 驱动: sqlite（默认）或 postgres
DATABASE_DRIVER=sqlite
# SQLite: 文件路径；Postgres: 连接字符串
DATABASE_DSN=data/claude-code-gateway.db

# Postgres 示例:
# DATABASE_DRIVER=postgres
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_USER=postgres
# DATABASE_PASSWORD=your_password
# DATABASE_DBNAME=ccgateway

# --- Redis（可选，留空则使用内存缓存） ---
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# --- 管理员 ---
ADMIN_PASSWORD=admin

# --- 出口指纹 ---
# craftls（默认，内置 Bun 指纹快照，会随 Claude Code 升级过时）
# bun_sidecar（推荐，经本地 Bun 边车发出，TLS 指纹永远等于真实 Bun，自动跟随）
# EGRESS_MODE=bun_sidecar
# BUN_SIDECAR_PORT=8788

# --- 身份模式 ---
# passthrough（默认,单人:客户端请求原样透传,最高保真)
# normalize（多人共号:把 home用户名/git/OS/device_id 归一化成账号固定虚拟身份,
#            让一个号始终像同一个人。版本/TLS 指纹不受影响)
# IDENTITY_MODE=passthrough

# --- 客户端限制 ---
# off    = 不限制（默认，普通 API 客户端也会被伪装成 CC 转发）
# ua     = 仅校验 User-Agent 是 claude-code/claude-cli
# strict = 严格：UA + 系统提示相似度 + 必需 header，只放行真实 Claude Code 客户端
CLIENT_RESTRICTION=off

# --- 日志 ---
# 级别: debug, info, warn, error
LOG_LEVEL=info

# --- 用量轮询 ---
# 账户 usage 数据自动刷新间隔（秒），默认 300（5 分钟）
USAGE_POLL_INTERVAL_SECS=300
